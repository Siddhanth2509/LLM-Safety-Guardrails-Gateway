generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GatewayLog {
  id          String   @id @default(cuid())
  requestId   String   @unique
  direction   String   // "input" or "output"
  inputText   String
  outputText  String?
  status      String   // "allowed", "blocked", "modified"
  blockedBy   String?  // which guardrail triggered
  reason      String?  // human-readable explanation
  latencyMs   Int
  piiFound    String?  // JSON array of detected PII
  createdAt   DateTime @default(now())
}

model PolicyRule {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String   // "input" or "output"
  type      String   // "pii", "prompt_injection", "topic", "schema", "toxicity"
  enabled   Boolean  @default(true)
  config    String   // JSON config for the rule
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}